TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_USERS=123456789,987654321

ADMIN_CHAT_ID=123456789
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ENABLE_RELEVANCE_FILTER=false
ENABLE_IMAGE_FILTER=false

# Polling configuration
POLL_TICK_MS=5000
MAX_CONCURRENT_SEARCHES=5

# Cloudflare protection
CURL_BIN=curl
PROXY_URL=http://proxyuser:proxypass@proxy.example.com:12345
CF_COOLDOWN_MS=300000
CF_MAX_COOLDOWN_MS=3600000
CF_ALERT_THROTTLE_MS=600000
REQUEST_JITTER_MS=2000
BROWSER_ID_ROTATE_MS=1800000
CACHE_TTL_MS=30000

# Enjoei search defaults
ENJOEI_CITY=sao-jose-dos-pinhais
ENJOEI_STATE=pr

# Server deployment
SSH_SERVER=user@hostname
SSH_PROJECT_DIR=~/enjoei-bot
