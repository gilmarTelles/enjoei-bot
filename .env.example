TELEGRAM_BOT_TOKEN=your_token_here
ALLOWED_USERS=chat_id1,chat_id2

ADMIN_CHAT_ID=your_chat_id
ANTHROPIC_API_KEY=your_key
ENABLE_RELEVANCE_FILTER=false
ENABLE_IMAGE_FILTER=false

# Polling configuration
POLL_BASE_INTERVAL_MS=5000
POLL_MAX_INTERVAL_MS=30000
POLL_BATCH_SIZE=4
POLL_IDLE_SLOWDOWN_CYCLES=5
MAX_CONCURRENT_SEARCHES=5

# Cloudflare protection
CURL_BIN=curl_chrome116
PROXY_URL=http://user:pass_country-br@geo.iproyal.com:12321
CF_COOLDOWN_MS=300000
CF_MAX_COOLDOWN_MS=3600000
CF_ALERT_THROTTLE_MS=600000
REQUEST_JITTER_MS=2000
BROWSER_ID_ROTATE_MS=1800000
CACHE_TTL_MS=30000

# Enjoei search defaults
ENJOEI_CITY=sao-jose-dos-pinhais
ENJOEI_STATE=pr

# Server deployment
SSH_SERVER=user@host
SSH_PROJECT_DIR=~/enjoei-bot
